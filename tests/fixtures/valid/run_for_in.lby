fn sum_array a array<i64> -> i64
    let s i64 = 0
    for x in a
        s += x
    s

fn count_vowels text string -> i64
    let n i64 = 0
    for c in text
        if c == 'a' or c == 'e' or c == 'i' or c == 'o' or c == 'u'
            n += 1
    n

fn sum_list -> i64
    let l list<i64> = list_new()
    l = push(l, 10)
    l = push(l, 20)
    l = push(l, 30)
    let s i64 = 0
    for v in l
        s += v
    s

fn main -> void
    let a array<i64> = [5, 10, 15, 20]
    wasm_log(sum_array(a))
    wasm_log(count_vowels("education"))
    wasm_log(sum_list())
