# Stage-5 user-defined generics: a trait bound on a generic type. `Ranked<T: Rank>`
# constrains its parameter by the `Rank` trait, so the type's inherent-impl method
# `score` may call the bound trait's `rank` method on the `T`-typed field. The
# bound is written on the declaration and propagates into `impl Ranked<T>`. Two
# impls of `Rank` (a struct `Card` and an enum `Coin`) supply two satisfying
# instantiations, `Ranked<Card>` and `Ranked<Coin>`; method dispatch on the bound
# trait is ordinary receiver dispatch at run time, so the program runs
# byte-for-byte identically on ast / ir / bytecode under erasure.

trait Rank
    fn rank self -> i64

struct Card
    value i64

enum Coin
    Heads
    Tails

impl Rank for Card
    fn rank self -> i64
        self.value * 10

impl Rank for Coin
    fn rank self -> i64
        match self
            Heads -> 1
            Tails -> 2

struct Ranked<T: Rank>
    item T

impl Ranked<T>
    # Type-checks because the declaration's `T: Rank` bound propagates into this
    # inherent impl: a `T` value may call `Rank`'s methods.
    fn score self -> i64
        self.item.rank() + 100

fn main -> i64
    let c Ranked<Card> = Ranked(Card(4))
    let k Ranked<Coin> = Ranked(Tails)
    # c.score() = 4*10 + 100 = 140 ; k.score() = 2 + 100 = 102 ; total 242
    c.score() + k.score()
