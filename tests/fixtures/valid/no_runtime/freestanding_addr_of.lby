# A freestanding (`no-runtime`) module exercising the stage-2 raw-pointer
# addressing surface: `addr_of` / `ptr_offset` / `ptr_cast`. All of it operates on
# a local array and a local struct (no host allocation), so the module is NOT
# rejected by the `no-runtime` gate and runs identically on every interpreter.
#
# main = 100 (array sum) + 8 (size law) + 10 (cast round-trip read of a[0])
#      + 9 (struct-field read) = 127.
no-runtime

struct Pair
    lo i64
    hi i64

fn main -> i64
    let a array<i64> = [10, 20, 30, 40]
    let pair Pair = Pair(7, 9)
    let total i64 = 0
    unsafe
        # addr_of an array element, then walk the array with element-scaled offsets.
        let base ptr<i64> = addr_of(a[0])
        let i i64 = 0
        while i < 4
            total = total + ptr_read(ptr_offset(base, i))
            i = i + 1
        # The size law: (base + 1) - base == size_of(i64) == 8.
        total = total + (ptr_to_int(ptr_offset(base, 1)) - ptr_to_int(base))
        # ptr_cast round-trip: ptr<i64> -> ptr<byte> -> ptr<i64>, read back a[0].
        let bp ptr<byte> = ptr_cast(base)
        let rp ptr<i64> = ptr_cast(bp)
        total = total + ptr_read(rp)
        # addr_of a struct field.
        let hp ptr<i64> = addr_of(pair.hi)
        total = total + ptr_read(hp)
    total
