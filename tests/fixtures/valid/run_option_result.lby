fn unwrap_or o option<i64> fallback i64 -> i64
    match o
        some(v) -> v
        none -> fallback

fn describe r result<i64, string> -> i64
    match r
        ok(v) -> v
        err(m) -> len(m)

fn pick flag bool -> option<i64>
    if flag
        return some(7)
    none

fn divide n i64 d i64 -> result<i64, string>
    if d == 0
        return err("divide by zero")
    ok(n / d)

fn main -> i64
    let a option<i64> = some(3)
    let b option<i64> = none
    let r result<i64, string> = ok(10)
    let e result<i64, string> = err("boom")
    let sum i64 = unwrap_or(a, 0) + unwrap_or(b, 100)
    let checked i64 = describe(r) + describe(e)
    let picked i64 = unwrap_or(pick(true), 0) + unwrap_or(pick(false), 1)
    let divided i64 = describe(divide(20, 4)) + describe(divide(1, 0))
    sum + checked + picked + divided
