fn build -> map<i64, i64>
    let m map<i64, i64> = map_new()
    m = map_set(m, 1, 100)
    m = map_set(m, 2, 200)
    m = map_set(m, 3, 300)
    m = map_set(m, 4, 400)
    m = map_set(m, 5, 500)
    m = map_set(m, 2, 999)
    m

fn lookup m map<i64, i64> k i64 -> i64
    match map_get(m, k)
        some(v) -> v
        none -> 0 - 1

fn main -> i64
    let m map<i64, i64> = build()
    let n i64 = map_len(m)
    let got2 i64 = lookup(m, 2)
    let got5 i64 = lookup(m, 5)
    let missing i64 = lookup(m, 42)
    let has3 i64 = 0
    if map_has(m, 3)
        has3 = 1
    let has99 i64 = 0
    if map_has(m, 99)
        has99 = 1
    n * 1000000 + got2 * 1000 + got5 + missing + has3 * 10 + has99
