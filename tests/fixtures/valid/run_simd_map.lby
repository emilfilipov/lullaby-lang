fn combine -> i64
    let a array<i64> = [1, 2, 3, 4, 5, 6, 7]
    let b array<i64> = [10, 20, 30, 40, 50, 60, 70]
    let c array<i64> = [0, 0, 0, 0, 0, 0, 0]
    let d array<i64> = [0, 0, 0, 0, 0, 0, 0]
    for i from 0 to 6
        c[i] = a[i] + b[i]
    for i from 0 to 6
        d[i] = b[i] - a[i]
    let s = 0
    for i from 0 to 6
        s += c[i] + d[i]
    s

fn main -> i64
    combine()
