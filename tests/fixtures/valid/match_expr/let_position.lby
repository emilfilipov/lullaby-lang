# `match` as an expression in `let` binding position, yielding `i64`. The
# binding annotation flows in as the expected result type; every arm yields
# `i64`, so the match's value initializes `x`.

enum P
    Even
    Odd

fn parity n i64 -> P
    if n % 2 == 0
        Even
    else
        Odd

fn classify n i64 -> i64
    let x i64 = match parity(n)
        Even -> 100
        Odd -> 200
    x + n

fn main -> i64
    let a i64 = classify(4)
    let b i64 = classify(3)
    println(to_string(a))
    println(to_string(b))
    a + b
